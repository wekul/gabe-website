generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String    @unique
  email         String?   @unique
  emailVerified DateTime? @map("emailVerified")
  image         String?
  role          String    @default("viewer")
  passwordHash  String?   @map("password_hash")
  modifiable    Boolean                    @default(true)
  accounts               Account[]
  sessions               Session[]
  deviceSessions         DeviceSession[]
  notificationRecipients DailyNotificationRecipient[]
  adminAuditLogs         AdminAuditLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("userId")
  type              String
  provider          String
  providerAccountId String  @map("providerAccountId")
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token")
  sessionState      String? @map("session_state")
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("sessionToken")
  userId       String   @map("userId")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model DeviceSession {
  token     String   @id
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("device_sessions")
}

model VerificationToken {
  identifier String
  expires    DateTime
  token      String

  @@id([identifier, token])
  @@map("verification_token")
}

model Role {
  name        String           @id
  description String?
  modifiable  Boolean          @default(true)
  rank        Int              @default(0)
  permissions RolePermission[]

  @@map("roles")
}

model RolePermission {
  roleName   String @map("role_name")
  permission String
  role       Role   @relation(fields: [roleName], references: [name], onDelete: Cascade)

  @@id([roleName, permission])
  @@map("role_permissions")
}

enum DeliveryType {
  post
  digital
}

model ShopItem {
  id              String       @id
  title           String
  description     String       @default("")
  imageUrl        String       @map("image_url")
  costPence       Int          @map("cost_pence")
  deliveryTime    String       @map("delivery_time")
  deliveryType    DeliveryType @map("delivery_type")
  displayOrder    Int          @default(0) @map("display_order")
  quantityTracked Boolean      @default(false) @map("quantity_tracked")
  quantity        Int?
  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([displayOrder(sort: Asc), createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("shop_items")
}

model SiteVisitor {
  id          String        @id
  firstSeenAt DateTime      @map("first_seen_at")
  lastSeenAt  DateTime      @map("last_seen_at")
  visitCount  Int           @map("visit_count")
  sessions    SiteSession[]
  imageViews  ImageView[]

  @@map("site_visitors")
}

model SiteSession {
  id                          String      @id
  visitorId                   String      @map("visitor_id")
  authenticatedUserIdentifier String?     @map("authenticated_user_identifier")
  path                        String
  startedAt       DateTime    @map("started_at")
  endedAt         DateTime?   @map("ended_at")
  durationSeconds Int?        @map("duration_seconds")
  maxStillSeconds Int?        @map("max_still_seconds")
  topStillPoint   String?     @map("top_still_point")
  visitor         SiteVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  @@index([startedAt(sort: Desc)])
  @@map("site_sessions")
}

model ContactMessage {
  id                          String   @id
  name                        String
  email                       String
  message                     String
  reason                      String   @default("unspecified")
  authenticatedUserIdentifier String?  @map("authenticated_user_identifier")
  createdAt                   DateTime @map("created_at")
  adminMessage                Boolean  @default(false)

  @@index([createdAt(sort: Desc)])
  @@map("contact_messages")
}

model ImageView {
  id                          String      @id
  imageId                     String      @map("image_id")
  visitorId                   String      @map("visitor_id")
  authenticatedUserIdentifier String?     @map("authenticated_user_identifier")
  path                        String
  viewedSeconds Int         @map("viewed_seconds")
  createdAt     DateTime    @map("created_at")
  visitor       SiteVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
  @@map("image_views")
}

model ImageSpotlightSetting {
  imageId String  @id @map("image_id")
  enabled Boolean @default(false)

  @@map("image_spotlight_settings")
}

model SiteTheme {
  id                String @id
  backgroundStyle   String @default("studio_gradient") @map("background_style")
  gradientStart     String @map("gradient_start")
  gradientEnd       String @map("gradient_end")
  gradientDirection Int    @default(155) @map("gradient_direction")
  gradientIntensity Int    @default(60) @map("gradient_intensity")
  accent            String
  surface           String
  surfaceStrong     String @map("surface_strong")
  text                  String
  mutedText             String  @map("muted_text")
  pageEditorBetaEnabled Boolean @default(false) @map("page_editor_beta_enabled")
  announcementEnabled   Boolean @default(false) @map("announcement_enabled")
  announcementText      String  @default("") @map("announcement_text")

  @@map("site_theme")
}

model DailyNotificationConfig {
  id         String                       @id
  enabled    Boolean                      @default(false)
  sendHour   Int                          @default(9) @map("send_hour")
  sendMinute Int                          @default(0) @map("send_minute")
  timezone   String                       @default("Europe/London")
  fromEmail  String?                      @map("from_email")
  updatedAt  DateTime                     @updatedAt @map("updated_at")
  recipients DailyNotificationRecipient[]

  @@map("daily_notification_config")
}

model DailyNotificationRecipient {
  configId String                  @map("config_id")
  userId   String                  @map("user_id")
  config   DailyNotificationConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  user     User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([configId, userId])
  @@map("daily_notification_recipients")
}

model EmailServerSecret {
  id                String   @id
  host              String
  port              Int      @default(587)
  secure            Boolean  @default(false)
  username          String?
  encryptedPassword String?  @map("encrypted_password")
  defaultFromEmail  String?  @map("default_from_email")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("email_server_secrets")
}





model StripeWebhookEvent {
  id                String    @id
  type              String
  livemode          Boolean   @default(false)
  status            String    @default("received")
  checkoutSessionId String?   @map("checkout_session_id")
  itemId            String?   @map("item_id")
  quantity          Int?
  payload           Json?
  errorMessage      String?   @map("error_message")
  receivedAt        DateTime  @default(now()) @map("received_at")
  processedAt       DateTime? @map("processed_at")

  @@index([type, receivedAt(sort: Desc)])
  @@index([status, receivedAt(sort: Desc)])
  @@map("stripe_webhook_events")
}

model PageContentBlock {
  id        String   @id @default(cuid())
  pageKey   String   @map("page_key")
  blockKey  String   @map("block_key")
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([pageKey, blockKey])
  @@index([pageKey])
  @@map("page_content_blocks")
}
model PageContentItem {
  id           String   @id @default(cuid())
  pageKey      String   @map("page_key")
  slotKey      String   @map("slot_key")
  title        String
  body         String
  imageUrl     String?  @map("image_url")
  linkLabel    String?  @map("link_label")
  linkHref     String?  @map("link_href")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([pageKey, slotKey, displayOrder])
  @@map("page_content_items")
}
model PageContentVersion {
  id                  String   @id @default(cuid())
  pageKey             String   @map("page_key")
  snapshot            Json
  label               String?
  createdByUserId     String?  @map("created_by_user_id")
  createdByIdentifier String?  @map("created_by_identifier")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([pageKey, createdAt(sort: Desc)])
  @@map("page_content_versions")
}

model AppErrorLog {
  id         String   @id @default(cuid())
  source     String
  message    String
  stack      String?
  context    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([source])
  @@map("app_error_logs")
}

model CriticalErrorLog {
  id              String    @id @default(cuid())
  source          String
  path            String?
  message         String
  stack           String?
  digest          String?
  userId          String?   @map("user_id")
  userIdentifier  String?   @map("user_identifier")
  context         Json?
  emailNotifiedAt DateTime? @map("email_notified_at")
  emailError      String?   @map("email_error")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([source])
  @@index([path])
  @@map("critical_error_logs")
}

model AdminAuditLog {
  id             String   @id @default(cuid())
  userId         String?  @map("user_id")
  userIdentifier String   @map("user_identifier")
  userRole       String?  @map("user_role")
  action         String
  section        String
  targetType     String?  @map("target_type")
  targetId       String?  @map("target_id")
  details        Json?
  createdAt      DateTime @default(now()) @map("created_at")
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([section])
  @@index([action])
  @@index([userId])
  @@map("admin_audit_logs")
}





